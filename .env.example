# === TELEGRAM ===
# Crear bot con @BotFather en Telegram y pegar el token aqui
TELEGRAM_BOT_TOKEN=pega_aqui_tu_bot_token
# Enviar mensaje al bot, luego abrir: https://api.telegram.org/bot[TOKEN]/getUpdates
# Buscar "chat":{"id": XXXXXXX} — ese es tu chat_id
TELEGRAM_CHAT_ID=pega_aqui_tu_chat_id

# === CLAUDE CODE CLI ===
# Windows: C:\Users\TU_USUARIO\AppData\Roaming\npm\claude.cmd
# Linux/Mac: claude
CLAUDE_CMD=claude

# === PROXY ===
PROXY_PORT=5055
