# === TELEGRAM ===
# Create a bot with @BotFather on Telegram and paste the token here
TELEGRAM_BOT_TOKEN=paste_your_bot_token_here
# Send a message to your bot, then open: https://api.telegram.org/bot[TOKEN]/getUpdates
# Look for "chat":{"id": XXXXXXX} — that's your chat_id
TELEGRAM_CHAT_ID=paste_your_chat_id_here

# === CLAUDE CODE CLI ===
# Windows: C:\Users\YOUR_USER\AppData\Roaming\npm\claude.cmd
# Linux/Mac: claude
CLAUDE_CMD=claude

# === PROXY ===
PROXY_PORT=5055
